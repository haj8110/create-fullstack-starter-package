{
  "name": "@haj8110/create-fullstack-starter",
  "version": "1.0.8",
  "type": "module",
  "description": "Production-grade CLI to scaffold a fullstack starter (Node.js + React).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haj8110/create-fullstack-starter-package.git"
  },
  "homepage": "https://github.com/haj8110/create-fullstack-starter-package#readme",
  "bugs": {
    "url": "https://github.com/haj8110/create-fullstack-starter-package/issues"
  },
  "keywords": [
    "create",
    "scaffold",
    "starter",
    "fullstack",
    "cli",
    "react",
    "vite",
    "express",
    "typescript"
  ],
  "bin": {
    "create-fullstack-starter": "bin/index.js"
  },
  "files": [
    "bin/",
    "dist/",
    "templates/"
  ],
  "engines": {
