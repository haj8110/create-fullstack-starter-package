  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.1",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.1",
    "inquirer": "^12.9.4",
    "ora": "^8.2.0",
    "validate-npm-package-name": "^6.0.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.12.2",
    "eslint": "^9.39.4",
    "tsup": "^8.5.0",
    "typescript": "~6.0.2"
  }
